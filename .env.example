PORT=3000
NODE_ENV=development

# Windows workaround for Prisma EPERM rename issues
PRISMA_CLIENT_ENGINE_TYPE=binary

# Prisma (MySQL)
DATABASE_URL="mysql://root:password@localhost:3306/jlpt_master"

# JWT
JWT_SECRET="change_me"
JWT_EXPIRES_IN="7d"

# Admin auth (optional, required if using password reset / Google login)
# Public base URL of the admin panel (used to build password reset links)
ADMIN_PANEL_URL="http://localhost:3001"

# Resend (password reset emails)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="onboarding@resend.dev"

# Google Sign-In (ID token verification)
GOOGLE_CLIENT_ID=""

# Optional: seed a super admin via `npm run seed`
ADMIN_SEED_EMAIL="admin@jlptmaster.local"
ADMIN_SEED_PASSWORD="change_me"
ADMIN_SEED_NAME="JLPT Master"

# Telegram Bot
# Create a bot token via @BotFather
TELEGRAM_BOT_TOKEN=""

# Chat/group ID that receives support notifications (can be negative for groups)
TELEGRAM_ADMIN_CHAT_ID=""

# Public base URL of THIS backend (required for Telegram webhook in production)
# Example (Railway): https://<service>.up.railway.app
BASE_URL=""

# Optional: force webhook mode on/off
# - production default: webhook
# - non-production default: long polling
TELEGRAM_USE_WEBHOOK=""

# Optional: enable verbose bot logs (default: off in production)
BOT_DEBUG=""

# Base URL for backend self-calls (only used for boot-time ping today)
BOT_BACKEND_URL="http://localhost:3000"
